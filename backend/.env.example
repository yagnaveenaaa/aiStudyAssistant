# Server
PORT=3000
NODE_ENV=development

# --- LLM provider (pick one) ---
# gemini = FREE, no billing — get key at https://aistudio.google.com/apikey
# groq   = FREE tier — https://console.groq.com/keys
# openai = paid billing required after free trial expires
LLM_PROVIDER=gemini

# Google Gemini (recommended for trial / free)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (only if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Shared LLM settings
LLM_MAX_TOKENS=2200
LLM_MAX_RETRIES=3

# Public API URL (empty = same origin)
PUBLIC_API_BASE=

# CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30

DATABASE_PATH=./data/study.db
